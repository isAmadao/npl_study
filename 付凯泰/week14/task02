        print("\n" + "=" * 60)
        print("步骤 4: 生成分析报告")
        print("=" * 60)
        analyzer.print_recommendation_report(ticker)

        # 6. 绘制分析图表
        print("\n" + "=" * 60)
        print("步骤 5: 绘制分析图表")
