# ============================================================
# RedisVL Agent Cache — 环境变量配置
# ============================================================
# 复制此文件为 .env 并按需修改
# cp .env.example .env

# ==================== Redis 配置 ====================
# 兼容低版本 Redis（6.x / 7.x），无需 Redis Stack 模块
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50
REDIS_DECODE_RESPONSES=true

# ==================== Milvus 配置 ====================
# 方式一：URI 连接（推荐，支持 Milvus Lite 和远程）
#   "milvus.db"               → Milvus Lite（嵌入式，无需 Docker）
#   "http://localhost:19530"   → 远程 Milvus / Docker
MILVUS_URI=
# 方式二：传统 host:port（向后兼容，仅在 URI 为空时使用）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=cache_vectors
MILVUS_METRIC_TYPE=IP          # IP(内积) 或 COSINE(余弦)

# ==================== Embedding 配置 ====================
# 支持的 provider: qwen | openai | sentence_transformers
#
# Qwen（通义千问）推荐模型:
#   text-embedding-v1  (1536 维，兼容)
#   text-embedding-v2  (1536 维，更优，推荐)
#
# 方式一：DashScope SDK（推荐）
#   pip install dashscope
#   设置 DASHSCOPE_API_KEY 或 EMBEDDING_API_KEY
#
# 方式二：OpenAI 兼容接口（自动降级）
#   无需 dashscope 库，仅需 openai 库 + api_key
#
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIM=1536
EMBEDDING_API_KEY="sk-9f96f86d7029428bbb74d78d33859df2"
# OpenAI 兼容端点（Qwen 也可用）:
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用 OpenAI 时:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-ada-002
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_API_BASE=https://api.openai.com/v1

# 使用本地模型时（provider = sentence_transformers）:
# EMBEDDING_PROVIDER=sentence_transformers
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_DIM=512

# ==================== Semantic Cache 配置 ====================
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_DEFAULT_TTL=86400            # 默认 24 小时
CACHE_MAX_SIZE=10000               # 最大缓存条目数
CACHE_EVICTION_POLICY=lru          # lru | lfu | ttl
CACHE_TOP_K=5                      # Top-K 搜索结果数
CACHE_ENABLE_STATS=true            # 是否启用命中率统计

# ==================== Semantic Router 配置 ====================
ROUTER_CONFIDENCE_THRESHOLD=0.75   # 路由置信度阈值
ROUTER_DEFAULT_ROUTE=fallback      # 默认兜底路由
ROUTER_CONFIG_PATH=                # 路由配置文件路径（可选 JSON/YAML）

# ==================== 日志配置 ====================
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # text | json
