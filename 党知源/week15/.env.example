# Mock mode: no Kafka/Milvus/GPU/LLM required (for homework & pytest)
MOCK_MODE=1

# SQLite
DB_PATH=./db.db

# Kafka (production)
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=rag-data

# Milvus Cloud (production)
MILVUS_URI=https://your-instance.cloud.zilliz.com.cn
MILVUS_TOKEN=your_token
MILVUS_COLLECTION=rag_data_new

# Embedding models
BGE_MODEL_PATH=/path/to/bge-small-zh-v1.5
CLIP_MODEL_PATH=/path/to/jina-clip-v2

# LLM (DashScope compatible)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# MinerU
MINERU_OUTPUT_DIR=./processed
MINERU_API_URL=http://127.0.0.1:30000

# Streamlit -> API
API_BASE=http://127.0.0.1:8000
